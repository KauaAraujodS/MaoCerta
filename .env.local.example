# Copie para .env.local (não versionado) ou configure as mesmas chaves na Vercel (Settings → Environment Variables).
#
# --- Supabase (Dashboard do projeto → Settings → API) ---
# NEXT_PUBLIC_SUPABASE_URL: Project URL (ex.: https://amrhutneryrkwkxxinzz.supabase.co)
# NEXT_PUBLIC_SUPABASE_ANON_KEY: chave "anon" "public" — formato JWT que começa com eyJ...
# SUPABASE_SERVICE_ROLE_KEY: chave "service_role" "secret" — também JWT eyJ... (só servidor/webhooks; nunca no client)
#
# --- Mercado Pago webhook (opcional) ---
# MERCADO_PAGO_WEBHOOK_SECRET: segredo que o endpoint /api/webhooks/mercado-pago valida no header
#
# Projeto remoto deste repo: amrhutneryrkwkxxinzz
NEXT_PUBLIC_SUPABASE_URL=https://amrhutneryrkwkxxinzz.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# MERCADO_PAGO_WEBHOOK_SECRET=
