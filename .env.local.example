# Copie para .env.local (não versionado) ou configure as mesmas chaves na Vercel (Settings → Environment Variables).
#
# --- Supabase (Dashboard do projeto → Settings → API) ---
# NEXT_PUBLIC_SUPABASE_URL: Project URL (ex.: https://amrhutneryrkwkxxinzz.supabase.co)
# NEXT_PUBLIC_SUPABASE_ANON_KEY: chave "anon" "public" — formato JWT que começa com eyJ...
# SUPABASE_SERVICE_ROLE_KEY: chave "service_role" "secret" — também JWT eyJ... (só servidor/webhooks; nunca no client)
#
# --- Mercado Pago (Developers → sua aplicação → Credenciais) ---
# NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY: public key (TEST-... ou APP_USR-...)
# MERCADO_PAGO_ACCESS_TOKEN: access token (APENAS server, NUNCA no client)
# MERCADO_PAGO_WEBHOOK_SECRET: string que você define; configure o MESMO valor no painel do MP
#
# --- URL pública do app ---
# NEXT_PUBLIC_APP_URL: usado pelo MP pra notification_url. Localmente http://localhost:3000;
#                     em produção https://SEU-DOMINIO.vercel.app
#
# Projeto remoto deste repo: amrhutneryrkwkxxinzz

NEXT_PUBLIC_SUPABASE_URL=https://amrhutneryrkwkxxinzz.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY=
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=

NEXT_PUBLIC_APP_URL=http://localhost:3000
