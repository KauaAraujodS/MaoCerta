# Copie este arquivo para secrets.ps1 (na mesma pasta) e preencha.
# scripts/secrets.ps1 NAO e versionado (.gitignore).

# Token da CONTA Supabase (comeca com sbp_): https://supabase.com/dashboard/account/tokens
$env:SUPABASE_ACCESS_TOKEN = "sbp_COLE_AQUI"

# Senha do Postgres do projeto: Dashboard do projeto -> Settings -> Database -> Database password
$env:SUPABASE_DB_PASSWORD = "COLE_AQUI"

# Opcional: deploy na Vercel pelo CLI — https://vercel.com/account/tokens
$env:VERCEL_TOKEN = ""
